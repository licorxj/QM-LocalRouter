# ============================================================
# LocalRouter - Environment Configuration Example
# ============================================================
# Copy this file to .env and customize:
#   cp .env.example .env        # Linux/macOS
#   copy .env.example .env       # Windows
#
# You can also set these values via environment variables.
# ============================================================

# --- Frontend ---
# Port for the Vite development server (frontend UI)
FRONTEND_PORT=12001

# --- Backend ---
# Port for the FastAPI backend
BACKEND_PORT=12002

# Optional: Override the default settings below by creating
# a backend/.env file with your custom values.
#
# Available backend options:
# HOST=127.0.0.1              # Bind address (use 0.0.0.0 for Docker/VPS)
# DATABASE_URL=sqlite+aiosqlite:///data/app.db  # Database path
# LOG_RETENTION_DAYS=30       # Days to keep request logs
# DEFAULT_TIMEOUT=120         # Default upstream request timeout (seconds)
# DEFAULT_RETRY_COUNT=2       # Default retry count on failure
# APP_NAME=LLM API Router     # Application name
# APP_VERSION=1.0.0           # Application version
# CORS_ORIGINS=["http://localhost:12001","http://127.0.0.1:12001"]
